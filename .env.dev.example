# .env.dev.example (개발 환경)
POSTGRES_USER=...
POSTGRES_PASSWORD=...
POSTGRES_DB=...

# --- DRIZZLE / APP CONFIG ---
# 포맷: postgres://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>
DATABASE_URL=...

# better_auth
BETTER_AUTH_SECRET=...
BETTER_AUTH_URL=...

# DB 모드: PGLITE (로컬 내장 DB) | POSTGRES (프로덕션)
USE_DATABASE_MODE=...

# --- 외부 API 키 ---
WEATHER_KOR=...
OPEN_DATA=...
AIR_KOREA_KEY=...
GITHUB_TOKEN=...

# TMAP API
TMAP_API=...

# 경로 최적화 모드 (NONE|TMAP|OSRM|BUILDING-AVOID)
ROUTE_MODE=...

# 서울 열린데이터광장 API 인증키
SEOUL_ACCESS_KEY=...

# 관리자 시드 비밀번호
ADMIN_SEED_PASSWORD=...
# 관리자 시드 이메일 (미설정 시 'admin@runnable.com' 기본값)
ADMIN_SEED_EMAIL=...

# 다이어그램 스튜디오 dev 백도어
DEVELOPER_SEED_PASSWORD=...
# Developer 시드 이메일 (미설정 시 'developer@runnable.com' 기본값)
DEVELOPER_SEED_EMAIL=...
