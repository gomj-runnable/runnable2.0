{
    "name": "runnable",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "prepare": "husky",
        "lint": "eslint app/ server/ shared/",
        "lint:fix": "eslint app/ server/ shared/ --fix",
        "format": "prettier --write .",
        "typecheck": "nuxt typecheck",
