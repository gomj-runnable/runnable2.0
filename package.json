        "@nuxt/ui": "^4.7.1",
        "@turf/turf": "^7.3.4",
        "better-auth": "^1.4.18",
        "cesium": "^1.140.0",
        "drizzle-orm": "^0.45.1",
        "lib": "link:@/lib",
        "nuxt": "^4.3.0",
        "p-limit": "^7.1.1",
        "p-retry": "^8.0.0",
        "papaparse": "^5.5.3",
        "pg": "^8.18.0",
        "tailwindcss": "^4.1.18",
        "ts-morph": "^28.0.0",
        "vue-mermaid-string": "^8.0.2",
        "xstate": "^5.31.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@nuxt/eslint": "^1.13.0",
        "@nuxt/eslint-config": "^1.13.0",
        "@nuxt/test-utils": "^4.0.3",
        "@tailwindcss/vite": "^4.1.18",
        "@types/node": "^25.2.0",
        "@types/papaparse": "^5.5.2",
        "@types/pg": "^8.16.0",
        "@types/proj4": "^2.19.0",
        "dotenv": "^17.2.4",
        "drizzle-kit": "^0.31.8",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.4",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.1",
        "proj4": "^2.20.8",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.5",
        "vue-tsc": "^3.2.4"
    },
    "packageManager": "pnpm@10.28.2",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "esbuild",
            "unrs-resolver",
            "vue-demi"
