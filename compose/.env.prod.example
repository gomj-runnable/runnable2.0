# compose/.env.prod.example — docker-compose 운영 환경 변수 템플릿
# 실제 값은 .env.prod 로 복사 후 채워서 사용 (gitignored).

# --- Postgres ---
POSTGRES_USER=...
POSTGRES_PASSWORD=...
POSTGRES_DB=...

# --- App 런타임 ---
NODE_ENV=production
PORT=3000
TZ=Asia/Seoul

# --- Auth ---
BETTER_AUTH_SECRET=...
BETTER_AUTH_URL=...
BETTER_AUTH_TRUSTED_ORIGINS=...

# --- DB 모드: PGLITE | POSTGRES ---
USE_DATABASE_MODE=POSTGRES

# --- 경로 최적화 모드 (NONE|TMAP|OSRM|BUILDING-AVOID) ---
ROUTE_MODE=...

# --- 외부 API ---
TMAP_API=...
WEATHER_KOR=...
OPEN_DATA=...
AIR_KOREA_KEY=...
GITHUB_TOKEN=...
SEOUL_ACCESS_KEY=...

# --- Webhook ---
WEBHOOK_SECRET=...

# --- Seed ---
ADMIN_SEED_EMAIL=...
ADMIN_SEED_PASSWORD=...
DEVELOPER_SEED_EMAIL=...
DEVELOPER_SEED_PASSWORD=...
