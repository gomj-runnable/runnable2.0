# compose/.env.prod.example — docker-compose 운영 환경 변수 템플릿
# 실제 값은 .env.prod 로 복사 후 채워서 사용 (gitignored).

# --- Postgres ---
POSTGRES_USER=...
POSTGRES_PASSWORD=...
POSTGRES_DB=...

# --- App 런타임 ---
ENVIRONMENT_MODE=PRODUCT
PORT=3000
TZ=Asia/Seoul

# --- Auth ---
BETTER_AUTH_SECRET=...
BETTER_AUTH_URL=...
BETTER_AUTH_TRUSTED_ORIGINS=...

# --- 경로 최적화 모드 (NONE|TMAP|OSRM|BUILDING-AVOID) ---
ROUTE_MODE=...

# --- 외부 API ---
TMAP_API_ACCESS_TOCKEN=...
WEATHER_KOR=...
OPEN_DATA=...
AIR_KOREA_KEY=...

# --- 지도 타일 (#368: 엔드포인트 .env 외부화) ---
# V-World WMTS 키 + 3D 타일셋/지형 URL. CSP connect-src 화이트리스트도 이 URL origin 으로 구성됨.
V_WORLD_ACCESS_TOCKEN=...
TILESET_URL=...
TERRAIN_URL=...

# --- Webhook ---
WEBHOOK_SECRET=...

# --- Seed ---
ADMIN_SEED_EMAIL=...
ADMIN_SEED_PASSWORD=...
DEVELOPER_SEED_EMAIL=...
DEVELOPER_SEED_PASSWORD=...
