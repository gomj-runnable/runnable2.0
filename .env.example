# .env.example (로컬용 기본 값)
POSTGRES_USER={user}
POSTGRES_PASSWORD={password}
POSTGRES_DB={db_name}

# --- DRIZZLE / APP CONFIG ---
# 포맷: postgres://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>
# 로컬 개발 시 HOST는 localhost
DATABASE_URL=postgres://{user}:{password}@{host}:{port}/{db_name}

# better_auth 임시 키 값
BETTER_AUTH_SECRET=...
# Base URL of your app
BETTER_AUTH_URL={baseUrl}

# DB 모드: PGLITE (로컬 내장 DB, 기본값) | POSTGRES (프로덕션)
USE_DATABASE_MODE=PGLITE

# --- MapPrime 지도 서버 ---
WEATHER_KOR=...
OPEN_DATA=...
# 에어코리아 API 키 (미설정 시 airquality 소스 비활성화)
AIR_KOREA_KEY=...
GITHUB_TOKEN=...

# TMAP API
TMAP_API=...

# 경로 최적화 모드 (NONE|TMAP|OSRM|BUILDING-AVOID)
ROUTE_MODE=NONE

# 서울 열린데이터광장 API 인증키 (물품보관함 좌표 매핑용)
SEOUL_ACCESS_KEY=...

# 관리자 시드 비밀번호 (PGLITE/POSTGRES 모드 DB 시드 공용)
ADMIN_SEED_PASSWORD=...
# 관리자 시드 이메일 (미설정 시 'admin@runnable.com' 기본값)
ADMIN_SEED_EMAIL=admin@runnable.com

# 다이어그램 스튜디오 dev 백도어 — NODE_ENV=production 에서는 시드 스킵.
# 정식 권한 체계 정립 시 이 변수와 관련 시드 모두 제거 검토 (#92 D3, #111).
DEVELOPER_SEED_PASSWORD=...
# Developer 시드 이메일 (미설정 시 'developer@runnable.com' 기본값)
DEVELOPER_SEED_EMAIL=developer@runnable.com
