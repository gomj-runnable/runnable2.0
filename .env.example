# .env.example (로컬용 기본 값)
POSTGRES_USER={user}
POSTGRES_PASSWORD={password}
POSTGRES_DB={db_name}

# --- DRIZZLE / APP CONFIG ---
# 포맷: postgres://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>
# 로컬 개발 시 HOST는 localhost
DATABASE_URL=postgres://{user}:{password}@{host}:{port}/{db_name}

# better_auth 임시 키 값
BETTER_AUTH_SECRET=...
# Base URL of your app
BETTER_AUTH_URL={baseUrl}

# 메모리로 임시 테스트(MEMORY|POSTGRES)
USE_DATABASE_MODE=MEMORY

# --- MapPrime 지도 서버 ---
WEATHER_KOR=...
OPEN_DATA=...
# 에어코리아 API 키 (미설정 시 OPEN_DATA 값을 사용)
AIR_KOREA_KEY=...
GITHUB_TOKEN=...

# TMAP API
TMAP_API=...

# 경로 최적화 모드 (NONE|TMAP|OSRM|BUILDING-AVOID)
ROUTE_MODE=NONE

# 서울 열린데이터광장 API 인증키 (물품보관함 좌표 매핑용)
SEOUL_ACCESS_KEY=...

# 관리자 시드 비밀번호 (MEMORY 모드 dev 유저 + POSTGRES 모드 DB 시드 공용)
ADMIN_SEED_PASSWORD=...