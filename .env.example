# .env.example (로컬용 기본 값)
POSTGRES_USER=root
POSTGRES_PASSWORD=root1234
POSTGRES_DB=runnable

# --- DRIZZLE / APP CONFIG ---
# 포맷: postgres://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>
# 로컬 개발 시 HOST는 localhost
DATABASE_URL=postgres://root:root1234@localhost:6432/runnable

# better_auth 임시 키 값
BETTER_AUTH_SECRET=...
# Base URL of your app
BETTER_AUTH_URL=http://localhost:3000

# 메모리로 임시 테스트(MEMORY|POSTGRES)
USE_DATABASE_MODE=MEMORY

# --- MapPrime 지도 서버 ---
WEATHER_KOR=...
OPEN_DATA=...
GITHUB_TOKEN=...

# TMAP API
TMAP_API=...

# 경로 최적화 모드 (NONE|TMAP|OSRM|BUILDING-AVOID)
ROUTE_MODE=NONE