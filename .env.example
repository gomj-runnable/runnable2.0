# .env.example (로컬용 기본 값)
POSTGRES_USER=root
POSTGRES_PASSWORD=root1234
POSTGRES_DB=runnable_db

# --- DRIZZLE / APP CONFIG ---
# 포맷: postgres://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>
# 로컬 개발 시 HOST는 localhost
DATABASE_URL=postgres://admin:church_pass_1234@localhost:6432/runnable_db

# better_auth 임시 키 값
BETTER_AUTH_SECRET=
# Base URL of your app
BETTER_AUTH_URL=http://localhost:3000

# --- MapPrime 지도 서버 ---
# /proxy/** 요청을 포워딩할 MapPrime 서버 주소
MAPPRIME_BASE_URL=https://imap.incheon.go.kr

# --- Weather (KMA API Hub) ---
# 기상청 API 허브 authKey
WEATHER_KOR=

# --- 공공데이터포털 (data.go.kr) ---
# 동네예보 + 에어코리아 대기오염 공용 인증키
OPEN_DATA=
