# ENVIRONMENT 모드: PRODUCT|DEVELOP
ENVIRONMENT_MODE=DEVELOP

# .env.example (로컬용 기본 값)
POSTGRES_USER={user}
POSTGRES_PASSWORD={password}
POSTGRES_DB={db_name}

# --- DRIZZLE / APP CONFIG ---
# 포맷: postgres://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>
# 로컬 개발 시 HOST는 localhost
DATABASE_URL=postgres://{user}:{password}@{host}:{port}/{db_name}

# better_auth 임시 키 값
BETTER_AUTH_SECRET={secret_key}
# Base URL of your app
BETTER_AUTH_URL={baseUrl}

# --- MapPrime 지도 서버 ---
WEATHER_KOR=...
OPEN_DATA=...
# 에어코리아 API 키 (미설정 시 airquality 소스 비활성화)
AIR_KOREA_KEY=...
# V-WORLD API Token
V_WORLD=...

# TMAP API
TMAP_API=...

# 경로 최적화 모드 (NONE|TMAP|OSRM|BUILDING-AVOID)
ROUTE_MODE=NONE

# 관리자 시드 비밀번호 (DB 시드 공용)
ADMIN_SEED_PASSWORD=admin12345
# 관리자 시드 이메일 (미설정 시 'admin@runnable.com' 기본값)
ADMIN_SEED_EMAIL=admin@runnable.com

# 다이어그램 스튜디오 dev 백도어 — NODE_ENV=production 에서는 시드 스킵.
# 정식 권한 체계 정립 시 이 변수와 관련 시드 모두 제거 검토 (#92 D3, #111).
DEVELOPER_SEED_PASSWORD=develop1234
# Developer 시드 이메일 (미설정 시 'develop@runnable.com' 기본값)
DEVELOPER_SEED_EMAIL=develop@runnable.com
